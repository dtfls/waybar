{
  "layer": "top",
  "position": "top",
  "height": 24,
  "margin-top": 0,
  "margin-left": 0,
  "margin-right": 0,
  "margin-bottom": 0,
  "spacing": 4,
  "reload_style_on_change": true,
  "modules-left": [
    "sway/workspaces",
    "sway/mode"
  ],
  "modules-center": [
    "custom/nowplaying"
  ],
  "modules-right": [
    "network",
    "custom/mic",
    "pulseaudio",
    "cpu",
    "memory",
    "custom/github",
    "tray",
    "clock"
  ],
  "sway/workspaces": {
    "all-outputs": true,
    "disable-scroll": true,
    "format": "{name}"
  },
  "sway/mode": {
    "format": "{}"
  },
  "custom/nowplaying": {
    "exec": "$HOME/.config/waybar/scripts/now-playing.sh",
    "return-type": "json",
    "interval": 1,
    "hide-empty-text": true,
    "max-length": 56,
    "on-click": "playerctl play-pause",
    "on-click-middle": "playerctl previous",
    "on-click-right": "playerctl next",
    "tooltip": true
  },
  "custom/github": {
    "exec": "$HOME/.config/waybar/scripts/github-prs.sh",
    "return-type": "json",
    "interval": 180,
    "signal": 8,
    "on-click": "xdg-open \"https://github.com/pulls?q=is%3Apr+is%3Aopen+%28author%3A%40me+OR+assignee%3A%40me+OR+review-requested%3A%40me%29\"",
    "on-click-middle": "pkill -SIGRTMIN+8 waybar",
    "on-click-right": "xdg-open \"https://github.com/pulls?q=is%3Apr+is%3Aopen+review-requested%3A%40me\"",
    "tooltip": true
  },
  "network": {
    "interval": 5,
    "format-wifi": "󰖩 {signalStrength}%",
    "format-ethernet": "󰈀",
    "format-linked": "󰈀",
    "format-disconnected": "󰖪 OFF",
    "tooltip-format-wifi": "{essid}\n{ipaddr}",
    "tooltip-format-ethernet": "{ifname}\n{ipaddr}",
    "tooltip-format-disconnected": "Network disconnected"
  },
  "custom/mic": {
    "exec": "$HOME/.config/waybar/scripts/mic-status.sh",
    "return-type": "json",
    "interval": 5,
    "on-click": "pactl set-source-mute @DEFAULT_SOURCE@ toggle",
    "on-scroll-up": "pactl set-source-volume @DEFAULT_SOURCE@ +5%",
    "on-scroll-down": "pactl set-source-volume @DEFAULT_SOURCE@ -5%",
    "tooltip": true
  },
  "pulseaudio": {
    "scroll-step": 5,
    "format": "{icon} {volume}%",
    "format-muted": "󰝟 OFF",
    "format-icons": {
      "default": [
        "󰕿",
        "󰖀",
        "󰕾"
      ]
    },
    "on-click": "pactl set-sink-mute @DEFAULT_SINK@ toggle",
    "on-click-right": "pavucontrol"
  },
  "cpu": {
    "interval": 2,
    "format": "󰍛 {usage}%",
    "tooltip": false
  },
  "memory": {
    "interval": 5,
    "format": "󰘚 {}%",
    "tooltip": false
  },
  "clock": {
    "interval": 1,
    "format": "󰥔 {:%d/%m %H:%M}",
    "tooltip-format": "<big>{:%A %d %B %Y}</big>\n<tt>{calendar}</tt>"
  },
  "tray": {
    "spacing": 8
  }
}
